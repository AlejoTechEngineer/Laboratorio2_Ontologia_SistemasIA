    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#F1Score">
        <rdf:type rdf:resource="#MetricaClasificacion"/>
        <nombreMetrica>F1-Score</nombreMetrica>
        <valorOptimo>Maximizar (media armónica entre precisión y recall)</valorOptimo>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#TopKAccuracy">
        <rdf:type rdf:resource="#MetricaClasificacion"/>
        <nombreMetrica>Top-5 Accuracy</nombreMetrica>
        <valorOptimo>Maximizar</valorOptimo>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#mAP">
        <rdf:type rdf:resource="#MetricaClasificacion"/>
        <nombreMetrica>mAP (Mean Average Precision)</nombreMetrica>
        <valorOptimo>Maximizar (valor entre 0 y 1)</valorOptimo>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#RMSE">
        <rdf:type rdf:resource="#MetricaRegresion"/>
        <nombreMetrica>RMSE (Root Mean Square Error)</nombreMetrica>
        <valorOptimo>Minimizar (cuanto más cercano a 0, mejor)</valorOptimo>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#BLEU">
        <rdf:type rdf:resource="#MetricaGeneracion"/>
        <nombreMetrica>BLEU Score</nombreMetrica>
        <valorOptimo>Maximizar (valor entre 0 y 1)</valorOptimo>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#FID">
        <rdf:type rdf:resource="#MetricaGeneracion"/>
        <nombreMetrica>FID (Fréchet Inception Distance)</nombreMetrica>
        <valorOptimo>Minimizar (cuanto más cercano a 0, mejor calidad de imagen)</valorOptimo>
    </owl:NamedIndividual>

